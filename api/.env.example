# Server Configuration
PORT=3000
NODE_ENV=development

# Stellar Network Configuration
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract Configuration
# REQUIRED: The application will fail to start if this is missing
CONTRACT_ID=

# Authentication
# REQUIRED: JWT Secret for signing tokens (minimum 32 characters)
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Request Timeout (ms)
REQUEST_TIMEOUT=30000

# Retry Configuration
MAX_RETRIES=3
RETRY_INITIAL_DELAY_MS=1000
RETRY_MAX_DELAY_MS=10000

# Request Body Size Limit
# Maximum request body size to prevent DoS attacks (e.g. 100kb, 1mb, 1gb)
# Returns 413 Payload Too Large when exceeded
BODY_SIZE_LIMIT=100kb
