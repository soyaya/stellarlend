# Stellar Network Config
STELLAR_NETWORK=testnet
# STELLAR_RPC_URL - Optional, will use network default if not set
# STELLAR_BASE_FEE - Optional, will use network default if not set
CONTRACT_ID=

# Admin Account (for signing txs)
ADMIN_SECRET_KEY=

# Price Source API Keys
COINGECKO_API_KEY=

# Cache Config
REDIS_URL=
CACHE_TTL_SECONDS=30

# Service Config
UPDATE_INTERVAL_MS=60000
MAX_PRICE_DEVIATION_PERCENT=10
PRICE_STALENESS_THRESHOLD_SECONDS=300

# Logging
LOG_LEVEL=info
