{
  "version": 2,
  "buildCommand": "cd api && npm ci && npm run build",
  "outputDirectory": "api/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/src/vercel.ts" }
  ],
  "functions": {
    "api/src/vercel.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "github": {
    "silent": true
  },
  "env": {
    "NODE_ENV": "production"
  }
}
